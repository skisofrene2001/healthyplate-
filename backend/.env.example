# PORT pour le backend
PORT=3001

# Base de données PostgreSQL (optionnel - sans elle le site tourne en mémoire)
DATABASE_URL=postgresql://user:password@host:5432/healthyplate

# Secret JWT (changez-le pour la prod !)
JWT_SECRET=change_this_to_a_random_secret_key_in_production

# Clé API Google Gemini (optionnel - sans elle, mode fallback)
GEMINI_API_KEY=your_gemini_api_key_here

# Client ID Google OAuth (pour la connexion avec Gmail)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
